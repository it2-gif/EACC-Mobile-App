rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && request.auth.token.role == 'admin';
    }

    function isSupportedRole() {
      return isSignedIn()
        && request.auth.token.role in ['student', 'teacher'];
    }

    function hasCourse(courseId) {
      return isSupportedRole()
        && request.auth.token.courseIds is list
        && courseId in request.auth.token.courseIds;
    }

    function isStudentThread(threadId) {
      return request.auth.token.role == 'student'
        && request.auth.token.lmsUserId == threadId;
    }

    function isAnnouncementThread(threadId) {
      return threadId == 'announcements';
    }

    function isTeacher() {
      return request.auth.token.role == 'teacher';
    }

    function canAccessThread(courseId, threadId) {
      return hasCourse(courseId)
        && (isTeacher() || isStudentThread(threadId) || isAnnouncementThread(threadId));
    }

    function canWriteThread(courseId, threadId) {
      return canAccessThread(courseId, threadId)
        && (!isAnnouncementThread(threadId) || isTeacher());
    }

    function hasValidSender() {
      return request.resource.data.sender_role == request.auth.token.role
        && request.resource.data.sender_name == request.auth.token.displayName;
    }

    function sameField(name) {
      return request.resource.data[name] == resource.data[name];
    }

    function isReadReceiptUpdate(threadId) {
      return request.resource.data.thread_id == threadId
        && sameField('last_message')
        && sameField('last_sender_name')
        && sameField('last_sender_role')
        && sameField('last_message_at')
        && (
          (
            request.auth.token.role == 'student'
            && request.resource.data.student_unread_count == 0
            && request.resource.data.student_last_read_at == request.time
            && sameField('teacher_unread_count')
            && sameField('teacher_last_read_at')
          )
          ||
          (
            request.auth.token.role == 'teacher'
            && request.resource.data.teacher_unread_count == 0
            && request.resource.data.teacher_last_read_at == request.time
            && sameField('student_unread_count')
            && sameField('student_last_read_at')
          )
        );
    }

    function isOutgoingThreadUpdate(threadId) {
      return request.resource.data.thread_id == threadId
        && request.resource.data.last_sender_role == request.auth.token.role
        && request.resource.data.last_sender_name == request.auth.token.displayName
        && (
          isTeacher()
          || request.resource.data.student_name == request.auth.token.displayName
        );
    }

    function isAdminThreadUpdate(threadId) {
      return request.resource.data.thread_id == threadId
        && request.resource.data.last_sender_role == 'admin'
        && request.resource.data.last_sender_name == request.auth.token.displayName;
    }

    function isAnnouncementPinThreadUpdate(threadId) {
      return isAnnouncementThread(threadId)
        && request.auth.token.role in ['teacher', 'admin']
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'thread_id',
          'title',
          'is_announcement',
          'pinned',
          'updated_at'
        ])
        && request.resource.data.thread_id == threadId
        && request.resource.data.is_announcement == true
        && request.resource.data.pinned is bool
        && request.resource.data.updated_at == request.time;
    }

    function isAnnouncementPinThreadCreate(threadId) {
      return isAnnouncementThread(threadId)
        && request.auth.token.role in ['teacher', 'admin']
        && request.resource.data.keys().hasOnly([
          'thread_id',
          'title',
          'is_announcement',
          'pinned',
          'updated_at'
        ])
        && request.resource.data.thread_id == threadId
        && request.resource.data.is_announcement == true
        && request.resource.data.pinned is bool
        && request.resource.data.updated_at == request.time;
    }

    function isAnnouncementReadUpdate(threadId) {
      return isAnnouncementThread(threadId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'thread_id',
          'is_announcement',
          'announcement_reads',
          'updated_at'
        ])
        && request.resource.data.thread_id == threadId
        && request.resource.data.is_announcement == true
        && request.resource.data.announcement_reads is map
        && request.resource.data.updated_at == request.time;
    }

    function isMessageOwner() {
      return resource.data.sender_role == request.auth.token.role
        && resource.data.sender_name == request.auth.token.displayName;
    }

    function isTextMessageEdit() {
      return resource.data.type == 'text'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'text',
          'edited_at'
        ])
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.edited_at == request.time;
    }

    function isSoftMessageDelete() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'deleted_at',
          'deleted_by_role',
          'deleted_by_name'
        ])
        && request.resource.data.deleted_at == request.time
        && request.resource.data.deleted_by_role == request.auth.token.role
        && request.resource.data.deleted_by_name == request.auth.token.displayName;
    }

    function isMessageReactionUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'reactions'
        ])
        && request.resource.data.reactions is map;
    }

    function isMessagePinUpdate() {
      return request.auth.token.role in ['teacher', 'admin']
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'pinned',
          'pinned_at',
          'pinned_by_role',
          'pinned_by_name'
        ])
        && request.resource.data.pinned is bool
        && (
          request.resource.data.pinned == false
          || (
            request.resource.data.pinned_at == request.time
            && request.resource.data.pinned_by_role == request.auth.token.role
            && request.resource.data.pinned_by_name == request.auth.token.displayName
          )
        );
    }

    function isAdminTeacherReadUpdate(threadId) {
      return threadId == 'admin_teacher'
        && request.resource.data.thread_id == threadId
        && sameField('last_message')
        && sameField('last_sender_name')
        && sameField('last_sender_role')
        && sameField('last_message_at')
        && (
          (
            request.auth.token.role == 'admin'
            && request.resource.data.admin_unread_count == 0
            && request.resource.data.admin_last_read_at == request.time
            && sameField('teacher_unread_count')
            && sameField('teacher_last_read_at')
          )
          ||
          (
            request.auth.token.role == 'teacher'
            && request.resource.data.teacher_unread_count == 0
            && request.resource.data.teacher_last_read_at == request.time
            && sameField('admin_unread_count')
            && sameField('admin_last_read_at')
          )
        );
    }

    match /courses/{courseId} {
      allow read: if isAdmin() || hasCourse(courseId);
      allow write: if false;

      match /threads/{threadId} {
        allow read: if isAdmin() || canAccessThread(courseId, threadId);
        allow create: if isAdmin()
            ? isAdminThreadUpdate(threadId)
            : canAccessThread(courseId, threadId)
              && (
                (canWriteThread(courseId, threadId) && isOutgoingThreadUpdate(threadId))
                || isAnnouncementPinThreadCreate(threadId)
              );
        allow update: if isAdmin()
            ? (
                isAdminThreadUpdate(threadId)
                || isAdminTeacherReadUpdate(threadId)
                || isAnnouncementPinThreadUpdate(threadId)
                || isAnnouncementReadUpdate(threadId)
              )
            : canAccessThread(courseId, threadId)
              && (
                (canWriteThread(courseId, threadId) && isOutgoingThreadUpdate(threadId))
                || isReadReceiptUpdate(threadId)
                || isAdminTeacherReadUpdate(threadId)
                || isAnnouncementReadUpdate(threadId)
                || isAnnouncementPinThreadUpdate(threadId)
              );
        allow delete: if false;

        match /messages/{messageId} {
          allow read: if isAdmin() || canAccessThread(courseId, threadId);
          allow create: if isAdmin()
              ? hasValidSender()
                && request.resource.data.type in ['text', 'image', 'video', 'voice', 'document']
                && request.resource.data.created_at == request.time
              : canWriteThread(courseId, threadId)
                && hasValidSender()
                && request.resource.data.type in ['text', 'image', 'video', 'voice', 'document']
                && request.resource.data.created_at == request.time;
          allow update: if isAdmin()
              ? (isTextMessageEdit() || isSoftMessageDelete() || isMessageReactionUpdate() || isMessagePinUpdate())
              : canAccessThread(courseId, threadId)
                && (
                  (
                    isMessageOwner()
                    && (isTextMessageEdit() || isSoftMessageDelete())
                  )
                  || isMessageReactionUpdate()
                  || isMessagePinUpdate()
                );
          allow delete: if false;
        }
      }
    }
  }
}
